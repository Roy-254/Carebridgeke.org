# Care Bridge Kenya — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-side only, NEVER expose to client

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used for building redirect URLs and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://carebridgekenya.com

# ─── Flutterwave (https://dashboard.flutterwave.com) ─────────────────────────
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx-X
# This must match what you set in Flutterwave's webhook settings: "Secret Hash"
FLW_SECRET_HASH=your-custom-webhook-secret-hash
# Register webhook URL in Flutterwave: POST https://yourdomain.com/api/webhooks/flutterwave

# ─── Resend (https://resend.com) ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Add a verified domain or use the sandbox address (onboarding@resend.dev) for testing

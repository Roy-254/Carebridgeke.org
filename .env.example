# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_eyJ...
# Service role key — NEVER expose to browser. Used in API routes only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_eyJ...

# ─── Flutterwave (Payment Gateway) ───────────────────────────
# Get from: https://dashboard.flutterwave.com/settings/apis
# Use test keys for development, live keys for production.
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
# Secret hash — set a random string, then configure the same value
# in Flutterwave Dashboard → Webhooks → Secret Hash
FLW_SECRET_HASH=your_random_webhook_secret_hash

# ─── Email (Resend) ──────────────────────────────────────────
# Sign up at resend.com (free: 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Application ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://carebridgeke-org.vercel.app
NEXT_PUBLIC_PLATFORM_FEE=0.05

# ─── Production (Vercel) ─────────────────────────────────────
# Set NEXT_PUBLIC_APP_URL to your Vercel URL in production:
# NEXT_PUBLIC_APP_URL=https://carebridgekenya.vercel.app

# ─── M-Pesa (Safaricom Daraja) ──────────────────────────────
# Get from: https://developer.safaricom.co.ke/
# Use sandbox credentials for TESTING, live for PRODUCTION.
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

